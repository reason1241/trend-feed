{
  "manifest_version": 3,
  "name": "trend-feed",
  "version": "0.1.0",
  "description": "A Chrome new tab RSS dashboard with a simple feed manager.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Manage RSS feeds",
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}
